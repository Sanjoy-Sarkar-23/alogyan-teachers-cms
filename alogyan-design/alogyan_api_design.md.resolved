## 9. Module: Reports

All report endpoints are **read-only** (teacher and admin only). Heavy responses are cached in Redis for 1 hour.

### Endpoints

```
GET    /reports/dashboard            KPI summary for teacher home
GET    /reports/attendance           Attendance report
GET    /reports/fees                 Fee collection report
GET    /reports/students             Per-student combined report
GET    /reports/attendance/export    CSV export
GET    /reports/fees/export          CSV export
```

### GET /reports/dashboard

**Response 200:**
```json
{
  "success": true,
  "data": {
    "totalStudents": 85,
    "activeBatches": 6,
    "feesCollectedThisMonth": 48000,
    "feesPendingThisMonth": 12000,
    "feesOverdue": 7500,
    "todaysBatches": [
      { "id": "b_xyz", "name": "Math Batch A", "time": "16:00", "students": 22 }
    ],
    "newLeads": 3,
    "attendanceTodayMarked": 4,
    "attendanceTodayPending": 2
  }
}
```

### GET /reports/attendance

**Query Params:**
```
?batchId=b_xyz          (optional — all batches if omitted)
&from=2026-03-01
&to=2026-03-31
&format=json            (json | csv)
```

**Response 200:**
```json
{
  "success": true,
  "data": {
    "period": { "from": "2026-03-01", "to": "2026-03-31" },
    "batches": [
      {
        "batchId": "b_xyz",
        "batchName": "Math Batch A",
        "totalClasses": 13,
        "students": [
          { "studentId": "s_abc123", "name": "Priya Sharma", "present": 11, "absent": 2, "percentage": 84.6 }
        ]
      }
    ]
  }
}
```

### GET /reports/fees

**Query Params:**
```
?month=2026-03
&batchId=b_xyz
```

**Response 200:**
```json
{
  "success": true,
  "data": {
    "month": "2026-03",
    "totalExpected": 60000,
    "totalCollected": 48000,
    "totalPending": 8500,
    "totalOverdue": 3500,
    "collectionRate": 80,
    "byBatch": [
      {
        "batchId": "b_xyz",
        "batchName": "Math Batch A",
        "expected": 33000,
        "collected": 28500,
        "pending": 3000,
        "overdue": 1500
      }
    ]
  }
}
```

### GET /reports/students

**Query Params:**
```
?studentId=s_abc123     (required)
&month=2026-03
```

**Response 200:**
```json
{
  "success": true,
  "data": {
    "student": {
      "id": "s_abc123",
      "name": "Priya Sharma",
      "phone": "9876543210",
      "grade": "10th"
    },
    "batches": ["Math Batch A", "Science Batch B"],
    "attendance": {
      "totalClasses": 26,
      "present": 22,
      "absent": 4,
      "percentage": 84.6
    },
    "fees": {
      "month": "2026-03",
      "records": [
        { "batchName": "Math Batch A", "amount": 1500, "status": "paid", "paidAt": "2026-03-08T00:00:00.000Z" },
        { "batchName": "Science Batch B", "amount": 1200, "status": "pending", "dueDate": "2026-03-10" }
      ]
    }
  }
}
```

### Export Endpoints

```
GET /reports/attendance/export?batchId=b_xyz&from=2026-03-01&to=2026-03-31
GET /reports/fees/export?month=2026-03
```

Returns `Content-Type: text/csv` with `Content-Disposition: attachment; filename="...csv"`.

---

## 10. GraphQL Schema

### Schema

```graphql
# ──────────────────────────────
# Scalars & Enums
# ──────────────────────────────
scalar DateTime
scalar Date           # YYYY-MM-DD
scalar Month          # YYYY-MM

enum StudentStatus { ACTIVE ARCHIVED }
enum BatchStatus   { ACTIVE PAUSED CLOSED }
enum AttendanceStatus { PRESENT ABSENT HOLIDAY }
enum FeeStatus     { PENDING PARTIAL PAID OVERDUE }
enum PaymentMode   { CASH UPI CHEQUE OTHER }
enum AnnouncementChannel { INAPP WHATSAPP }
enum UserRole      { TEACHER ADMIN STUDENT }
enum SortOrder     { ASC DESC }

# ──────────────────────────────
# Core Types
# ──────────────────────────────
type Teacher {
  id: ID!
  name: String!
  phone: String!
  email: String
  slug: String!
  bio: String
  subjects: [String!]!
  plan: String!
  isVerified: Boolean!
  createdAt: DateTime!

  students(page: Int, pageSize: Int, search: String, isArchived: Boolean): StudentConnection!
  batches(status: BatchStatus): [Batch!]!
  announcements(page: Int, pageSize: Int): AnnouncementConnection!
  dashboard: DashboardSummary!
}

type Student {
  id: ID!
  name: String!
  phone: String!
  parentPhone: String
  grade: String
  address: String
  isArchived: Boolean!
  createdAt: DateTime!
  teacherId: ID!

  batches: [Batch!]!
  feeHistory(month: Month): [FeeRecord!]!
  attendanceSummary(batchId: ID, from: Date, to: Date): AttendanceSummary!
}

type Batch {
  id: ID!
  name: String!
  subject: String
  schedule: Schedule!
  feesPerMonth: Int!
  maxSeats: Int!
  currentSeats: Int!
  status: BatchStatus!
  term: String
  teacherId: ID!
  createdAt: DateTime!

  students: [Student!]!
  attendance(from: Date!, to: Date!): [AttendanceRecord!]!
  fees(month: Month): [FeeRecord!]!
  attendanceSummary(month: Month!): BatchAttendanceSummary!
}

type Schedule {
  days: [String!]!
  time: String!
  durationMinutes: Int!
}

type AttendanceRecord {
  id: ID!
  date: Date!
  batchId: ID!
  records: [AttendanceEntry!]!
  markedAt: DateTime!
}

type AttendanceEntry {
  studentId: ID!
  studentName: String!
  status: AttendanceStatus!
}

type AttendanceSummary {
  totalClasses: Int!
  present: Int!
  absent: Int!
  percentage: Float!
}

type BatchAttendanceSummary {
  month: Month!
  totalClasses: Int!
  students: [StudentAttendanceStat!]!
}

type StudentAttendanceStat {
  studentId: ID!
  studentName: String!
  present: Int!
  absent: Int!
  percentage: Float!
}

type FeeRecord {
  id: ID!
  studentId: ID!
  studentName: String!
  batchId: ID!
  batchName: String!
  amount: Int!
  paidAmount: Int!
  balance: Int!
  dueDate: Date!
  month: Month!
  status: FeeStatus!
  paymentMode: PaymentMode
  paidAt: DateTime
  memo: String
}

type Note {
  id: ID!
  title: String!
  subject: String
  batchId: ID
  batchName: String
  storageUrl: String!
  fileType: String!
  fileSizeBytes: Int!
  uploadedAt: DateTime!
}

type Announcement {
  id: ID!
  title: String!
  message: String!
  targetBatchId: ID
  targetBatchName: String
  channels: [AnnouncementChannel!]!
  isPinned: Boolean!
  sentAt: DateTime
  scheduledAt: DateTime
  whatsappLinks: [String!]!
}

type DashboardSummary {
  totalStudents: Int!
  activeBatches: Int!
  feesCollectedThisMonth: Int!
  feesPendingThisMonth: Int!
  feesOverdue: Int!
  newLeads: Int!
  todaysBatches: [TodayBatch!]!
  attendanceTodayMarked: Int!
  attendanceTodayPending: Int!
}

type TodayBatch {
  id: ID!
  name: String!
  time: String!
  students: Int!
}

# ──────────────────────────────
# Pagination (Relay-style)
# ──────────────────────────────
type StudentConnection {
  edges: [StudentEdge!]!
  pageInfo: PageInfo!
  totalCount: Int!
}
type StudentEdge { node: Student! cursor: String! }

type AnnouncementConnection {
  edges: [AnnouncementEdge!]!
  pageInfo: PageInfo!
  totalCount: Int!
}
type AnnouncementEdge { node: Announcement! cursor: String! }

type PageInfo {
  hasNextPage: Boolean!
  hasPreviousPage: Boolean!
  startCursor: String
  endCursor: String
}

# ──────────────────────────────
# Queries
# ──────────────────────────────
type Query {
  # Auth context
  me: Teacher!

  # Students
  student(id: ID!): Student
  students(
    page: Int
    pageSize: Int
    search: String
    batchId: ID
    isArchived: Boolean
    sortBy: String
    sortOrder: SortOrder
  ): StudentConnection!

  # Batches
  batch(id: ID!): Batch
  batches(status: BatchStatus): [Batch!]!

  # Attendance
  attendance(batchId: ID!, from: Date!, to: Date!): [AttendanceRecord!]!
  attendanceSummary(batchId: ID!, month: Month!): BatchAttendanceSummary!

  # Fees
  feeRecord(id: ID!): FeeRecord
  feeRecords(
    status: FeeStatus
    batchId: ID
    studentId: ID
    month: Month
    page: Int
    pageSize: Int
  ): FeeRecordConnection!

  # Notes
  notes(batchId: ID, fileType: String, page: Int, pageSize: Int): NoteConnection!
  note(id: ID!): Note

  # Announcements
  announcements(batchId: ID, isPinned: Boolean, page: Int, pageSize: Int): AnnouncementConnection!
  announcement(id: ID!): Announcement

  # Reports
  dashboard: DashboardSummary!
  attendanceReport(batchId: ID, from: Date!, to: Date!): AttendanceReport!
  feeReport(month: Month!, batchId: ID): FeeReport!
  studentReport(studentId: ID!, month: Month): StudentReport!
}

# ──────────────────────────────
# Mutations
# ──────────────────────────────
type Mutation {
  # Students
  createStudent(input: CreateStudentInput!): StudentPayload!
  updateStudent(id: ID!, input: UpdateStudentInput!): StudentPayload!
  archiveStudent(id: ID!): BooleanPayload!
  bulkImportStudents(batchId: ID, csvUrl: String!): BulkImportPayload!

  # Batches
  createBatch(input: CreateBatchInput!): BatchPayload!
  updateBatch(id: ID!, input: UpdateBatchInput!): BatchPayload!
  enrollStudents(batchId: ID!, studentIds: [ID!]!): EnrollPayload!
  removeStudents(batchId: ID!, studentIds: [ID!]!): BooleanPayload!
  cloneBatch(id: ID!, input: CloneBatchInput!): BatchPayload!

  # Attendance
  markAttendance(batchId: ID!, input: MarkAttendanceInput!): AttendanceRecord!
  updateAttendance(batchId: ID!, date: Date!, input: MarkAttendanceInput!): AttendanceRecord!

  # Fees
  generateFees(input: GenerateFeesInput!): GenerateFeesPayload!
  markFeePaid(id: ID!, input: MarkPaidInput!): FeeRecord!
  markFeePartial(id: ID!, input: MarkPartialInput!): FeeRecord!

  # Notes
  requestUploadUrl(input: UploadUrlInput!): UploadUrlPayload!
  saveNote(input: SaveNoteInput!): NotePayload!
  deleteNote(id: ID!): BooleanPayload!

  # Announcements
  createAnnouncement(input: CreateAnnouncementInput!): AnnouncementPayload!
  updateAnnouncement(id: ID!, input: UpdateAnnouncementInput!): AnnouncementPayload!
  togglePinAnnouncement(id: ID!): AnnouncementPayload!
  deleteAnnouncement(id: ID!): BooleanPayload!
}

# ──────────────────────────────
# Subscriptions (Real-time)
# ──────────────────────────────
type Subscription {
  newLead(teacherId: ID!): Lead!
  feeUpdated(teacherId: ID!): FeeRecord!
}

# ──────────────────────────────
# Input Types
# ──────────────────────────────
input CreateStudentInput {
  name: String!
  phone: String!
  parentPhone: String
  grade: String
  address: String
  batchIds: [ID!]
}

input UpdateStudentInput {
  name: String
  phone: String
  parentPhone: String
  grade: String
  address: String
}

input CreateBatchInput {
  name: String!
  subject: String
  schedule: ScheduleInput!
  feesPerMonth: Int!
  maxSeats: Int
  term: String
}

input ScheduleInput {
  days: [String!]!
  time: String!
  durationMinutes: Int!
}

input UpdateBatchInput {
  name: String
  subject: String
  schedule: ScheduleInput
  feesPerMonth: Int
  maxSeats: Int
  status: BatchStatus
  term: String
}

input CloneBatchInput {
  newName: String!
  term: String!
  copyStudents: Boolean
}

input MarkAttendanceInput {
  date: Date!
  records: [AttendanceEntryInput!]!
}

input AttendanceEntryInput {
  studentId: ID!
  status: AttendanceStatus!
}

input GenerateFeesInput {
  batchId: ID!
  month: Month!
  amount: Int!
  dueDate: Date!
}

input MarkPaidInput {
  paymentMode: PaymentMode!
  paidAt: DateTime
  memo: String
}

input MarkPartialInput {
  paidAmount: Int!
  paymentMode: PaymentMode!
  memo: String
}

input UploadUrlInput {
  fileName: String!
  fileType: String!
  fileSizeBytes: Int!
}

input SaveNoteInput {
  title: String!
  subject: String
  batchId: ID
  storageKey: String!
  fileType: String!
  fileSizeBytes: Int!
}

input CreateAnnouncementInput {
  title: String!
  message: String!
  targetBatchId: ID
  channels: [AnnouncementChannel!]!
  scheduledAt: DateTime
}

input UpdateAnnouncementInput {
  title: String
  message: String
  targetBatchId: ID
  channels: [AnnouncementChannel!]
  scheduledAt: DateTime
}

# ──────────────────────────────
# Payload (Mutation Response) Types
# ──────────────────────────────
type StudentPayload    { student: Student errors: [FieldError!]! }
type BatchPayload      { batch: Batch errors: [FieldError!]! }
type NotePayload       { note: Note errors: [FieldError!]! }
type AnnouncementPayload { announcement: Announcement errors: [FieldError!]! }
type BooleanPayload    { success: Boolean! errors: [FieldError!]! }
type EnrollPayload     { enrolled: Int! errors: [FieldError!]! }
type GenerateFeesPayload { created: Int! skipped: Int! errors: [FieldError!]! }
type BulkImportPayload { imported: Int! skipped: Int! rowErrors: [RowError!]! }
type UploadUrlPayload  { uploadUrl: String! storageKey: String! expiresAt: DateTime! }

type FieldError  { field: String message: String! }
type RowError    { row: Int! reason: String! }

# ──────────────────────────────
# Report Types
# ──────────────────────────────
type AttendanceReport {
  period: DateRange!
  batches: [BatchAttendanceData!]!
}

type DateRange { from: Date! to: Date! }

type BatchAttendanceData {
  batchId: ID!
  batchName: String!
  totalClasses: Int!
  students: [StudentAttendanceStat!]!
}

type FeeReport {
  month: Month!
  totalExpected: Int!
  totalCollected: Int!
  totalPending: Int!
  totalOverdue: Int!
  collectionRate: Float!
  byBatch: [BatchFeeData!]!
}

type BatchFeeData {
  batchId: ID!
  batchName: String!
  expected: Int!
  collected: Int!
  pending: Int!
  overdue: Int!
}

type StudentReport {
  student: Student!
  attendance: AttendanceSummary!
  fees: [FeeRecord!]!
}

# Additional connection types
type FeeRecordConnection { edges: [FeeRecordEdge!]! pageInfo: PageInfo! totalCount: Int! }
type FeeRecordEdge { node: FeeRecord! cursor: String! }
type NoteConnection { edges: [NoteEdge!]! pageInfo: PageInfo! totalCount: Int! }
type NoteEdge { node: Note! cursor: String! }

# Lead type (read-only from teacher perspective)
type Lead {
  id: ID!
  name: String!
  phone: String!
  grade: String
  message: String
  status: String!
  receivedAt: DateTime!
}
```

---

## 11. GraphQL Example Operations

### Query: Dashboard

```graphql
query Dashboard {
  dashboard {
    totalStudents
    activeBatches
    feesCollectedThisMonth
    feesPendingThisMonth
    feesOverdue
    newLeads
    todoaysBatches { id name time students }
    attendanceTodayMarked
    attendanceTodayPending
  }
}
```

### Query: Students List

```graphql
query Students($search: String, $batchId: ID) {
  students(page: 1, pageSize: 20, search: $search, batchId: $batchId) {
    totalCount
    pageInfo { hasNextPage endCursor }
    edges {
      node {
        id name phone grade isArchived
        batches { id name }
        attendanceSummary { percentage }
      }
    }
  }
}
```

### Mutation: Mark Attendance

```graphql
mutation MarkAttendance($batchId: ID!, $date: Date!, $records: [AttendanceEntryInput!]!) {
  markAttendance(batchId: $batchId, input: { date: $date, records: $records }) {
    date
    records { studentId studentName status }
    markedAt
  }
}
```

### Mutation: Generate Fee Records

```graphql
mutation GenerateFees($input: GenerateFeesInput!) {
  generateFees(input: $input) {
    created
    skipped
    errors { field message }
  }
}
```

### Subscription: New Lead Alert

```graphql
subscription NewLead($teacherId: ID!) {
  newLead(teacherId: $teacherId) {
    id name phone grade message status receivedAt
  }
}
```

---

## 12. DataLoader Strategy (N+1 Prevention)

```
Loaders instantiated per request in GraphQL context:

studentLoader          → batch by studentId[]
batchLoader            → batch by batchId[]
enrollmentsByBatch     → batch by batchId[] → returns Student[]
feesByStudent          → batch by studentId[] → returns FeeRecord[]
attendanceByBatch      → batch by batchId[] → returns AttendanceRecord[]
notesByBatch           → batch by batchId[] → returns Note[]
```

---

## 13. Rate Limits

| Endpoint Category | Authenticated | Unauthenticated |
|---|---|---|
| Standard API calls | 100 req/min | 20 req/min |
| Bulk import | 5 req/min | — |
| Report export | 10 req/min | — |
| Lead submission [PUBLIC] | — | 3 req/hr per IP |
| Upload URL generation | 20 req/min | — |

Rate limit headers returned:
```
X-RateLimit-Limit: 100
X-RateLimit-Remaining: 87
X-RateLimit-Reset: 1742584020
```

